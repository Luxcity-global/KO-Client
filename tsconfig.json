{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "incremental": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@ko/types": ["./packages/types/src/index.ts"],
      "@ko/types/*": ["./packages/types/src/*"],
      "@ko/utils": ["./packages/utils/src/index.ts"],
      "@ko/utils/*": ["./packages/utils/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".next"]
}
